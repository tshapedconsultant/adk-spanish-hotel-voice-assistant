# Copy this file to `.env` and fill in real values.
# Project author: Andres Lage | Copyright (c) 2026 Andres Lage (MIT — see LICENSE).

# Google Gemini API key (KEEP SECRET, DO NOT COMMIT)
GOOGLE_API_KEY=

# --- Amadeus GDS (precios y disponibilidad reales) ---
# Registro gratuito: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Test: https://test.api.amadeus.com | Producción: https://api.amadeus.com
AMADEUS_API_HOST=https://test.api.amadeus.com
USE_AMADEUS_HOTEL_TOOLS=true
DEFAULT_HOTEL_CITY=Las Palmas

# Optional: PMS / booking propio (si no usa Amadeus Hotel Booking)
HOTEL_BOOKING_API=
HOTEL_API_TOKEN=

# Main chat model (default: gemini-3.5-flash). Free tier has low daily limits per model.
GEMINI_MODEL=gemini-3.5-flash
# If you see quota errors, use 2.0 for chat or split with ROUTING_MODEL below:
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Redis for shared sessions across workers / replicas (requires `pip install redis`)
# REDIS_URL=redis://localhost:6379/0
# REDIS_KEY_PREFIX=adk:hotel:sess:
# SESSION_TIMEOUT_MINUTES=30

# Intent + entity extraction (Gemini structured JSON by default; set false for keyword-only)
# USE_STRUCTURED_ROUTING=true
# USE_INTENT_FUNCTION_CALLING=false
# Intent routing model (default gemini-2.0-flash — saves 3.5 quota for chat)
# ROUTING_MODEL=gemini-2.0-flash

# Optional: model for /webhook/transcribe (defaults try gemini-2.0-flash first)
# TRANSCRIBE_MODEL=gemini-2.0-flash

# Optional: protect /session/<id> endpoint in production (compared with constant-time digest)
SESSION_API_KEY=

# Optional: require X-Webhook-Key or Authorization: Bearer on webhook POST routes
# WEBHOOK_API_KEY=

# Max POST /webhook/trigger per client IP per minute (0 = disabled)
# WEBHOOK_RATE_LIMIT_PER_MINUTE=60

# Behind nginx/ingress: set trusted proxy hops (1 = one trusted reverse proxy) so rate limiting
# uses a safe client IP (Werkzeug ProxyFix). 0 = direct connections (typical local dev).
# TRUSTED_PROXY_HOPS=0

# Max JSON body size for Flask (bytes)
# MAX_REQUEST_BYTES=262144

